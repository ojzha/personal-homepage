---
import { ArrowRight, Download, ExternalLink } from "lucide-astro";
import { Image } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import PublicationCard from "@components/PublicationCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { profile } from "@data/profile";
import { publications } from "@data/publications";
import { projects } from "@data/projects";
import { withBase } from "@utils/paths";
import portraitImage from "../assets/images/profile/portrait.webp";

const featuredPublications = publications.filter((publication) => publication.featured).slice(0, 4);
const featuredProjects = projects.filter((project) => project.featured).slice(0, 2);
---

<Layout>
  <section class="home-intro">
    <div class="profile-panel">
      <p class="section-kicker home-affiliation-line">
        {profile.affiliation}（教育部直属，国家“985工程”“211工程”和“双一流”建设高校） · {profile.degree}
      </p>
      <h1>{profile.name}</h1>
      <p class="english-name">{profile.englishName}</p>
      <p class="tagline">{profile.tagline}</p>
      <p class="summary">{profile.summary}</p>
      <div class="action-row">
        <a class="button primary" href={withBase("/publications")}>查看论文成果 <ArrowRight size={17} /></a>
        <a class="button secondary" href={withBase("/files/GCX_resume_v5.pdf")}>下载个人简历 PDF <Download size={17} /></a>
      </div>
      <div class="profile-links" aria-label="公开学术链接">
        {
          profile.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">
              {link.label} <ExternalLink size={15} />
            </a>
          ))
        }
      </div>
    </div>

    <aside class="overview-panel portrait-panel">
      <div class="portrait-frame">
        <Image src={portraitImage} alt="龚城圩个人头像" loading="eager" />
      </div>
      <div class="stats-compact">
        {profile.stats.map((item) => <div><strong>{item.value}</strong><span>{item.label}</span></div>)}
      </div>
    </aside>
  </section>

  <section class="section-block">
    <div class="section-title">
      <p class="section-kicker">研究方向</p>
      <h2>围绕复杂样本智能检测，连接传感、建模与系统实现。</h2>
      <p>{profile.focus}</p>
    </div>
    <div class="keyword-grid">
      {profile.researchKeywords.map((keyword) => <span>{keyword}</span>)}
    </div>
    <div class="info-grid">
      {profile.publicInfo.map((item) => (
        <div>
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </div>
  </section>

  <section class="section-block">
    <div class="section-title-row">
      <div>
        <p class="section-kicker">代表论文</p>
        <h2>第一作者等效与高影响力合作成果</h2>
      </div>
      <a class="text-link" href={withBase("/publications")}>全部论文 <ArrowRight size={16} /></a>
    </div>
    <div class="publication-list compact-list">
      {featuredPublications.map((publication, index) => <PublicationCard publication={publication} index={index + 1} />)}
    </div>
  </section>

  <section class="section-block">
    <div class="section-title-row">
      <div>
        <p class="section-kicker">科研项目</p>
        <h2>从传感数据到检测系统</h2>
      </div>
      <a class="text-link" href={withBase("/projects")}>全部项目 <ArrowRight size={16} /></a>
    </div>
    <div class="project-list">
      {featuredProjects.map((project) => <ProjectCard project={project} />)}
    </div>
  </section>

</Layout>
